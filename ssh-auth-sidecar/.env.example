# HTTP port the sidecar listens on (the frontend proxies here).
SSH_AUTH_PORT=4000

# Host and port of the cluster we SSH into.
SSH_HOST=cluster.example.com
SSH_PORT=22

# Timeout (ms) before we treat the cluster as unreachable.
SSH_READY_TIMEOUT=10000

# Allowed CORS origins, comma-separated. '*' allows everything (dev only). In
# production set the frontend domain(s), e.g.:
#   SSH_AUTH_ALLOW_ORIGIN=https://metascheduler.example.com
SSH_AUTH_ALLOW_ORIGIN=*

# ── Abuse limits ─────────────────────────────────────────────────────────────
# Brute force: failed credential attempts per IP before locking, and how long
# the lock lasts in ms. The browser throttle is just UX; this is the real limit.
LOGIN_MAX_FAILS=5
LOGIN_LOCK_MS=900000

# Guest launches allowed per IP per minute (this endpoint has no auth).
GUEST_MAX_PER_MIN=10

# true ONLY if the sidecar sits behind a trusted reverse proxy (nginx/traefik);
# then it reads the real client IP from X-Forwarded-For.
TRUST_PROXY=false

# ── Fixed guest jobs ─────────────────────────────────────────────────────────
# With no SSH or password, the guest launches one of two predefined jobs (one
# SGE, one Hadoop). The only thing it picks is the type; /jobs/launch-guest
# validates that scheduler_type ('S' or 'H') and ignores anything else from the
# browser, using only the values below (the form pre-fill is cosmetic — a guest
# could send a tampered POST from DevTools, so the source of truth is here).
GUEST_OWNER=metascheduler

# SGE job (scheduler_type = S).
GUEST_SGE_NAME=guest_demo_sge
GUEST_SGE_PATH=/home/metascheduler/demo/job.sh
GUEST_SGE_PWD=/home/metascheduler/demo/
GUEST_SGE_QUEUE=1
GUEST_SGE_OPTIONS=

# Hadoop job (scheduler_type = H).
GUEST_HADOOP_NAME=guest_demo_hadoop
GUEST_HADOOP_PATH=/home/metascheduler/demo/job.jar
GUEST_HADOOP_PWD=/home/metascheduler/demo/
GUEST_HADOOP_QUEUE=2
GUEST_HADOOP_OPTIONS=wordcount test.txt out1
